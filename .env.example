# this file represents the .env file layout for local development by other developers

DB_KEY = #password will go here
DB_HOST = #localhost or wherever you choose to host this
DB_NAME = #name of your database
DB_USER = # your username for the DB you choose to use

SMTP_HOST = # SMTP server hostname (e.g. smtp.gmail.com)
SMTP_PORT = # SMTP port (e.g. 587 for TLS, 465 for SSL)
SMTP_SECURE = # true for port 465 (SSL), false for other ports
SMTP_USER = # email address used to send reset emails
SMTP_PASS = # password or app-specific password for the SMTP account